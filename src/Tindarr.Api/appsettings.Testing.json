{
  "BaseUrl": {
    "Mode": "Auto",
    "Lan": "http://localhost:5000",
    "Wan": "http://localhost:5000"
  },
  "Database": {
    "Provider": "Sqlite",
    "DataDir": "",
    "SqliteFileName": "tindarr_test.db",
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": true
  },
  "Jwt": {
    "Issuer": "tindarr",
    "Audience": "tindarr-client",
    "AccessTokenMinutes": 60,
    "SigningKeysFileName": "jwt-signing-keys-test.json",
    "AllowDevHeaderFallback": false
  },
  "Registration": {
    "AllowOpenRegistration": true,
    "DefaultRole": "Contributor",
    "PasswordHashIterations": 10000
  },
  "ApiRateLimit": {
    "Enabled": false
  },
  "Tmdb": {
    "ApiKey": "",
    "BaseUrl": "https://api.themoviedb.org/3/",
    "RequestsPerSecond": 1,
    "OperationTimeoutSeconds": 5
  }
}
