<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Tindarr" Language="1033" Version="1.0.2" Manufacturer="Tindarr" UpgradeCode="B7E9E7E5-9A2C-4E8B-9F1D-3C5E7E9A2B4D">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" InstallPrivileges="elevated" Description="Tindarr Web API and UI" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Tindarr is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <Icon Id="ProductIcon" SourceFile="..\..\..\artifacts\tindarr.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <!-- Port for merged UI/API (saved to port.txt). API reads from ProgramData\Tindarr\port.txt. -->
    <Property Id="PORT_PROPERTY" Value="6565" />
    <!-- Checkboxes: 1 = checked. Run batch files elevated when checked. -->
    <Property Id="INSTALL_SERVICE" Value="0" />
    <Property Id="OPEN_PORTS" Value="0" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="Tindarr" />
      </Directory>
      <Directory Id="CommonAppDataFolder" />
    </Directory>

    <Feature Id="ProductFeature" Title="Tindarr" Level="1" ConfigurableDirectory="INSTALLDIR">
      <ComponentGroupRef Id="ApiFiles" />
      <ComponentRef Id="BatchFiles" />
    </Feature>

    <!-- Batch files (installer/*.bat) installed to INSTALLDIR -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="BatchFiles" Guid="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D">
        <File Id="AddFirewallRulesBat" Source="..\..\add-firewall-rules.bat" KeyPath="yes" />
        <File Id="InstallServiceBat" Source="..\..\install-service.bat" />
        <File Id="RemoveFirewallRulesBat" Source="..\..\remove-firewall-rules.bat" />
        <File Id="UninstallServiceBat" Source="..\..\uninstall-service.bat" />
      </Component>
    </DirectoryRef>

    <!-- ApiFiles ComponentGroup is supplied by Heat harvest of publish output (see build script). -->

    <!-- Post-install: write port to port.txt (install dir + ProgramData\Tindarr), optionally run batch files elevated. -->
    <Binary Id="PostInstallVbs" SourceFile="TindarrPostInstall.vbs" />
    <CustomAction Id="SetPostInstallData" Property="PostInstall" Value="[INSTALLDIR]|[PORT_PROPERTY]|[INSTALL_SERVICE]|[OPEN_PORTS]|[CommonAppDataFolder]" />
    <CustomAction Id="PostInstall" BinaryKey="PostInstallVbs" VBScriptCall="PostInstall" Execute="deferred" Impersonate="no" Return="check" />

    <!-- Uninstall: stop service, remove service, remove firewall rules (runs before RemoveFiles). -->
    <CustomAction Id="SetUninstallData" Property="PostUninstall" Value="[INSTALLDIR]" />
    <CustomAction Id="PostUninstall" BinaryKey="PostInstallVbs" VBScriptCall="PostUninstall" Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- SetPostInstallData must run before deferred phase so PostInstall receives CustomActionData. -->
    <InstallExecuteSequence>
      <Custom Action="SetPostInstallData" After="CostFinalize">NOT Installed</Custom>
      <Custom Action="PostInstall" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="SetUninstallData" Before="RemoveFiles">REMOVE~="ALL"</Custom>
      <Custom Action="PostUninstall" After="SetUninstallData">REMOVE~="ALL"</Custom>
    </InstallExecuteSequence>

    <UIRef Id="WixUI_Tindarr" />
  </Product>
</Wix>
